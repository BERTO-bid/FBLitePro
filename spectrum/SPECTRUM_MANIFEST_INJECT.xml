<!--
  ════════════════════════════════════════════════════════
  SPECTRUM LITE PRO — Blok ini di-inject ke AndroidManifest
  FB Lite oleh GitHub Actions (main.yml) saat build.
  Tambahkan SEBELUM tag </application> di AndroidManifest.xml
  ════════════════════════════════════════════════════════
-->

<!-- Permissions Spectrum -->
<uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
<uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
<uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
<uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>
<uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29"/>

<!-- Spectrum Main Activity (tersembunyi dari launcher) -->
<activity
    android:name="com.spectrum.v2.MainActivity"
    android:exported="false"
    android:launchMode="singleTop"
    android:theme="@style/SpectrumTheme"/>

<activity
    android:name="com.spectrum.v2.EmailActivity"
    android:exported="false"/>

<!-- Floating overlay service -->
<service
    android:name="com.spectrum.v2.FloatingService"
    android:exported="false"/>

<!-- FB Login + Cookie Extractor (satu proses dengan FB Lite) -->
<service
    android:name="com.spectrum.v2.FbLoginService"
    android:exported="false"
    android:foregroundServiceType="dataSync"/>

<!-- Accessibility Service — klik UI FB Lite seperti manusia -->
<service
    android:name="com.spectrum.v2.SvAccessibilityService"
    android:exported="true"
    android:label="Lite Pro"
    android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
    <intent-filter>
        <action android:name="android.accessibilityservice.AccessibilityService"/>
    </intent-filter>
    <meta-data
        android:name="android.accessibilityservice"
        android:resource="@xml/sv2_accessibility"/>
</service>

<!-- FileProvider internal Spectrum -->
<provider
    android:name="androidx.core.content.FileProvider"
    android:authorities="com.facebook.lite.spectrum.provider"
    android:exported="false"
    android:grantUriPermissions="true">
    <meta-data
        android:name="android.support.FILE_PROVIDER_PATHS"
        android:resource="@xml/provider_paths"/>
</provider>
