<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floatContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="4dp">

    <ImageView
        android:id="@+id/yinYangView"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:src="@drawable/ic_bbm_toggle"
        android:scaleType="fitCenter"
        android:layout_marginBottom="4dp"/>

    <ImageView
        android:id="@+id/fabXClose"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/ic_close"
        android:padding="8dp"
        android:visibility="gone"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:id="@+id/fabGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView android:id="@+id/fabEmail"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@drawable/ic_email" android:padding="8dp"
            android:layout_marginBottom="4dp" android:background="@drawable/fab_circle_dark"/>

        <ImageView android:id="@+id/fabNama"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@drawable/ic_edit" android:padding="8dp"
            android:layout_marginBottom="4dp" android:background="@drawable/fab_circle_dark"/>

        <ImageView android:id="@+id/fabPass"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@drawable/ic_key" android:padding="8dp"
            android:layout_marginBottom="4dp" android:background="@drawable/fab_circle_dark"/>

        <ImageView android:id="@+id/fabPhone"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@drawable/ic_phone" android:padding="8dp"
            android:layout_marginBottom="4dp" android:background="@drawable/fab_circle_dark"/>

        <ImageView android:id="@+id/fabSave"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@drawable/ic_save" android:padding="8dp"
            android:layout_marginBottom="4dp" android:background="@drawable/fab_circle_dark"/>

        <ImageView android:id="@+id/fab2FA"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@drawable/ic_2fa" android:padding="8dp"
            android:layout_marginBottom="4dp" android:background="@drawable/fab_circle_dark"/>

        <ImageView android:id="@+id/fabClear"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@drawable/ic_delete" android:padding="8dp"
            android:layout_marginBottom="4dp" android:background="@drawable/fab_circle_dark"/>

        <ImageView android:id="@+id/fabPhoto"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@drawable/ic_photo_profile" android:padding="8dp"
            android:layout_marginBottom="4dp" android:background="@drawable/fab_circle_dark"/>

        <ImageView android:id="@+id/fabGear"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@drawable/ic_gear" android:padding="8dp"
            android:layout_marginBottom="4dp" android:background="@drawable/fab_circle_dark"/>

        <ImageView android:id="@+id/fabClose"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@drawable/ic_close" android:padding="8dp"
            android:background="@drawable/fab_circle_red"/>

    </LinearLayout>
</LinearLayout>
